      <owl:onProperty rdf:resource="#hasTerm"/>
      <owl:allValuesFrom rdf:resource="#Term"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasLocation"/>
      <owl:allValuesFrom rdf:resource="#Location"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasPostSituationDescription"/>
