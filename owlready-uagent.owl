    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf rdf:resource="#Instruction"/>
</owl:Class>

<owl:Class rdf:about="#Instruction">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#asRule"/>
      <owl:someValuesFrom rdf:resource="#Rule"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#asString"/>
      <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#ActionType"/>

<owl:Class rdf:about="#Constant">
  <rdfs:subClassOf rdf:resource="#Function"/>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasArity"/>
      <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#nonPositiveInteger"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Function">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasArity"/>
      <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasTerm"/>
      <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf rdf:resource="#Term"/>
  <rdfs:subClassOf>
    <owl:Class>
      <owl:complementOf rdf:resource="#Variable"/>
    </owl:Class>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Term">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasIndex"/>
      <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasIndex"/>
      <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Location"/>

<owl:Class rdf:about="#ItemColor"/>

<owl:Class rdf:about="#ItemDescription">
