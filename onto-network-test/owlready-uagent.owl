<Instruction rdf:about="#initialInstruction">
  <asGroundRuleString>appearsOn(letter,screen),subject(subject),button(space_bar),letter(letter),screen(screen) =&gt; press(subject,space_bar)</asGroundRuleString>
  <asGroundRuleString>isPartOf(subject,psychomotor-vigilance),subject(subject),task(psychomotor-vigilance) =&gt; hasProperty(psychomotor-vigilance,active)</asGroundRuleString>
  <asGroundRuleString>hasProperty(psychomotor-vigilance,active),letter(letter),screen(screen),task(psychomotor-vigilance) =&gt; appearsOn(letter,screen)</asGroundRuleString>
  <asRuleString>appearsOn(K,C),subject(I),button(H),letter(K),screen(C) =&gt; press(I,H)</asRuleString>
  <asRuleString>isPartOf(M,A),subject(M),task(A) =&gt; hasProperty(A,active)</asRuleString>
  <asRuleString>hasProperty(A,active),letter(S),screen(C),task(A) =&gt; appearsOn(S,C)</asRuleString>
  <asReasonerFactString>press(subject,space_bar)</asReasonerFactString>
  <asReasonerFactString>appearsOn(letter,screen)</asReasonerFactString>
  <asReasonerFactString>hasProperty(psychomotor-vigilance,active)</asReasonerFactString>
  <asFactString>task(psychomotor-vigilance)</asFactString>
  <asFactString>screen(screen)</asFactString>
  <asFactString>isPartOf(space_bar,psychomotor-vigilance)</asFactString>
  <asFactString>button(space_bar)</asFactString>
  <asFactString>letter(letter)</asFactString>
  <asFactString>isPartOf(subject,psychomotor-vigilance)</asFactString>
  <asFactString>subject(subject)</asFactString>
  <asFactString>isPartOf(letter,psychomotor-vigilance)</asFactString>
  <asFactString>isPartOf(screen,psychomotor-vigilance)</asFactString>
</Instruction>

