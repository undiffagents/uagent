    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#refersToItemType"/>
      <owl:onClass rdf:resource="#ItemType"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#ISR-MATBTask">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#providesRole"/>
