  <hasProperty rdf:resource="#active> <http://www.uagent.com/ontology#dlGraph"/>
</onto11:dlGraph>

<onto10:dlGraph rdf:about="#hasProperty"/>

<onto8:dlGraph rdf:about="#button"/>

<onto9:dlGraph rdf:about="#active"/>

