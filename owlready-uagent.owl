<onto8:dlGraph rdf:about="#task"/>

<onto9:dlGraph rdf:about="#space_bar">
  <rdf:type rdf:resource="#button> <http://www.uagent.com/ontology#dlGraph"/>
  <beIn rdf:resource="#psychomotor-vigilance> <http://www.uagent.com/ontology#dlGraph"/>
</onto9:dlGraph>

