         xmlns:onto9="http://www.w3.org/2002/07/owl#NamedIndividual> <http://www.uagent.com/ontology#"
         xmlns:onto10="http://www.w3.org/2002/07/owl#ObjectProperty> <http://www.uagent.com/ontology#"
         xmlns:onto11="#task> <http://www.uagent.com/ontology#">

<owl:Ontology rdf:about="http://www.uagent.com/ontology">
  <owl:versionIRI rdf:resource="http://www.uagent.com/ontology/1.0.0"/>
</owl:Ontology>

<owl:ObjectProperty rdf:about="#hasHeadPredicate"/>

<owl:ObjectProperty rdf:about="#contributesTo"/>

<owl:ObjectProperty rdf:about="#hasLocation"/>

<owl:ObjectProperty rdf:about="#providesRole"/>

<owl:ObjectProperty rdf:about="#triggers"/>

