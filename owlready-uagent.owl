<owl:ObjectProperty rdf:about="#hasSecondItem"/>

<owl:DatatypeProperty rdf:about="#isPresent"/>

<owl:DatatypeProperty rdf:about="#hasArity"/>

<owl:DatatypeProperty rdf:about="#asString"/>

<owl:DatatypeProperty rdf:about="#hasName"/>

<owl:DatatypeProperty rdf:about="#hasItemName"/>

<owl:DatatypeProperty rdf:about="#asDRSString">
  <rdfs:subPropertyOf rdf:resource="#asString"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#hasIndex"/>

<owl:DatatypeProperty rdf:about="#inReasoningStep"/>

<owl:Class rdf:about="#Predicate">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasArity"/>
      <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasTerm"/>
      <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#SituationDescription">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasCurrentCondition"/>
      <owl:allValuesFrom>
        <owl:Class>
          <owl:unionOf rdf:parseType="Collection">
            <rdf:Description rdf:about="#ItemDescription"/>
            <rdf:Description rdf:about="#RelativeCondition"/>
          </owl:unionOf>
        </owl:Class>
      </owl:allValuesFrom>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasEarlierCondition"/>
      <owl:allValuesFrom rdf:resource="#ItemDescription"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#ItemRole">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#assumedBy"/>
      <owl:someValuesFrom rdf:resource="#Item"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#assumedBy"/>
      <owl:allValuesFrom rdf:resource="#Item"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#RelativeConditionType"/>

<owl:Class rdf:about="#ItemLocation"/>

<owl:Class rdf:about="#TransitionDescription"/>

<owl:Class rdf:about="#ItemShape"/>

<owl:Class rdf:about="#Rule">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasBodyPredicate"/>
      <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasHeadPredicate"/>
      <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#inReasoningStep"/>
      <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#nonNegativeInteger"/>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Item">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#affords"/>
