<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://www.uagent.com/ontology"
         xmlns="http://www.uagent.com/ontology#"
         xmlns:onto="#Constant> <http://www.uagent.com/ontology#"
         xmlns:onto2="#Instruction> <http://www.uagent.com/ontology#"
         xmlns:onto3="#Predicate> <http://www.uagent.com/ontology#"
         xmlns:onto4="#Variable> <http://www.uagent.com/ontology#"
         xmlns:onto5="#Function> <http://www.uagent.com/ontology#"
         xmlns:onto6="#Fact> <http://www.uagent.com/ontology#"
         xmlns:onto7="#Rule> <http://www.uagent.com/ontology#"
