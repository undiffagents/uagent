    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#hasHeadPredicate"/>
      <owl:allValuesFrom rdf:resource="#Predicate"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
