      <owl:allValuesFrom rdf:resource="#TransitionDescription"/>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf rdf:resource="#Instruction"/>
</owl:Class>

<owl:Class rdf:about="#Action">
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#triggers"/>
      <owl:onClass rdf:resource="#TransitionDescription"/>
      <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:minQualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#ofActionType"/>
      <owl:onClass rdf:resource="#ActionType"/>
      <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
    </owl:Restriction>
  </rdfs:subClassOf>
</owl:Class>

<owl:Class rdf:about="#Fact">
  <rdfs:subClassOf rdf:resource="#Rule"/>
  <rdfs:subClassOf>
