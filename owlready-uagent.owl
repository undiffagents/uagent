    </owl:Restriction>
  </rdfs:subClassOf>
  <rdfs:subClassOf>
    <owl:Restriction>
      <owl:onProperty rdf:resource="#refersToItemColor"/>
      <owl:onClass rdf:resource="#ItemColor"/>
